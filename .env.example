PORT=5000
MONGODB_URI=mongodb://localhost:27017/rentgear
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:5173

# Email (SMTP). Leave SMTP_HOST empty in dev to log emails instead of sending.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_user
SMTP_PASS=your_pass
FROM_EMAIL=noreply@rentgear.com
FROM_NAME=RentGear
